# AI BI Smart — mẫu biến môi trường (copy thành .env, không commit secret)

# --- Ollama / LLM ---
SQL_MODEL=sqlcoder:7b
INSIGHT_MODEL=qwen2.5:14b
NARRATIVE_MODE=fast
OLLAMA_HOST=http://127.0.0.1:11434

# --- API ---
API_BASE=http://127.0.0.1:2004
CORS_ORIGINS=http://localhost:3010,http://127.0.0.1:3010
# Để trống = không bắt auth (dev). Set key mạnh khi demo/share URL.
API_KEY=

# --- Enterprise / Multi-tenant ---
# true = bật tenant/user/API key store + seed admin mặc định
AUTH_MULTI_TENANT=false
DEFAULT_TENANT_NAME=Default Tenant
DEFAULT_ADMIN_EMAIL=admin@local
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=Admin
# Rate limit theo API key + IP (request/phút)
API_RATE_LIMIT_PER_MINUTE=120
# White-label mặc định (tenant có thể ghi đè)
BRAND_PRODUCT_NAME=AI BI Smart
BRAND_PRIMARY_COLOR=#0f766e
BRAND_LOGO_URL=
# --- Domain DB (ưu tiên hơn configs/*.json) ---
# FINANCE_VNFDATA_DB_URL=postgresql+psycopg2://user:pass@host:5432/vnfdatadb

# --- Schema RAG / cache ---
SCHEMA_RAG_ENABLED=true
SCHEMA_RAG_MAX_TABLES=12
QUERY_CACHE_ENABLED=true
QUERY_CACHE_TTL_SECONDS=1800
# Semantic cache: hit khi câu hỏi diễn đạt khác nhưng cùng ý (Jaccard token)
QUERY_CACHE_SEMANTIC=true
QUERY_CACHE_SEMANTIC_THRESHOLD=0.82

# --- Alert Engine scheduler ---
# true = tự chạy rule mỗi N phút khi uvicorn sống
ALERT_SCHEDULE_ENABLED=false
ALERT_SCHEDULE_MINUTES=15

# --- Auto Article Scheduler (VNFDATA) ---
# true = tự viết bài theo giờ cố định + polling DB khi uvicorn sống
ARTICLE_SCHEDULE_ENABLED=false
ARTICLE_POLL_MINUTES=15
ARTICLE_DAILY_TIME=15:20
ARTICLE_WEEKLY_TIME=08:30
ARTICLE_DAILY_ENABLED=true
ARTICLE_WEEKLY_ENABLED=true
# true = khi DB cập nhật trong cùng ngày/kỳ (không chỉ đổi trade_date) → viết lại bài theo khung giờ
ARTICLE_INTRADAY_ENABLED=true

# --- Auto Article Notify (gửi bài khi job ok) ---
# true = gửi ra kênh đã cấu hình sau mỗi bài viết thành công
ARTICLE_NOTIFY_ENABLED=false
# Để trống = mọi trigger. Ví dụ chỉ schedule: schedule_daily,schedule_weekly
ARTICLE_NOTIFY_TRIGGERS=

# Email SMTP
ARTICLE_NOTIFY_SMTP_HOST=
ARTICLE_NOTIFY_SMTP_PORT=587
ARTICLE_NOTIFY_SMTP_USER=
ARTICLE_NOTIFY_SMTP_PASSWORD=
ARTICLE_NOTIFY_SMTP_TLS=true
ARTICLE_NOTIFY_EMAIL_FROM=
# Nhiều người: cách nhau bằng dấu phẩy
ARTICLE_NOTIFY_EMAIL_TO=

# Slack Incoming Webhook URL
ARTICLE_NOTIFY_SLACK_WEBHOOK=

# Telegram Bot (@BotFather) + chat_id nhóm/cá nhân
ARTICLE_NOTIFY_TELEGRAM_BOT_TOKEN=
ARTICLE_NOTIFY_TELEGRAM_CHAT_ID=

# true = gửi alert mới ra email/Slack/Telegram (dùng credential ARTICLE_NOTIFY_*)
ALERT_NOTIFY_ENABLED=false

# --- SSO (Single Sign-On) ---
# disabled | oidc | saml
SSO_PROVIDER=disabled

# OIDC — Google Workspace / Azure AD / Keycloak
SSO_OIDC_CLIENT_ID=
SSO_OIDC_CLIENT_SECRET=
# Google: https://accounts.google.com/.well-known/openid-configuration
# Azure : https://login.microsoftonline.com/{tenant_id}/v2.0/.well-known/openid-configuration
SSO_OIDC_DISCOVERY_URL=
SSO_OIDC_REDIRECT_URI=http://localhost:2004/api/v1/sso/callback
SSO_OIDC_SCOPE=openid email profile

# SAML 2.0 — Azure AD Enterprise App / Okta / ADFS
SSO_SAML_IDP_METADATA_URL=
SSO_SAML_SP_ENTITY_ID=ai-bi-smart
SSO_SAML_SP_ACS_URL=http://localhost:2004/api/v1/sso/saml/acs
SSO_SAML_IDP_CERT=
SSO_SAML_CERT_FILE=
SSO_SAML_KEY_FILE=
